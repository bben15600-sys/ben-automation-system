# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Notion integration token (Internal Integration → "Internal Integration Token")
NOTION_TOKEN=secret_...

# Rotation Schedule DB ID (already in CLAUDE.md)
ROTATION_DB_ID=ac656f74-60b6-41a3-adc2-49e6656c3845

# Weekly Schedule DB ID — find it:
#   1. Open the Weekly Schedule DB in Notion
#   2. Click ··· → Copy link to view
#   3. The 32-char ID is the last part of the URL (before any ?v=...)
WEEKLY_DB_ID=
