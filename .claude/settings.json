{
  "project": {
    "name": "ben-automation-system",
    "description": "Personal AI automation system \u2014 Claude Code as engine, Notion as data layer"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash"
    ]
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/auto-handoff/scripts/counter.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/auto-handoff/scripts/load-latest.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/skills/auto-handoff/scripts/session-end.sh\""
          }
        ]
      }
    ]
  }
}
